generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
}

model Tenant {
  id           String       @id @default(uuid())
  name         String
  email        String
  subdomain    String       @unique
  status       TenantStatus @default(PENDING)
  rejectReason String?
  tunnelId     String?
  tunnelToken  String?
  ztAppId      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  activatedAt  DateTime?

  auth              TenantAuth?
  sharingApprovals  SharingApproval[] @relation("requester")
  sharingApprovedBy SharingApproval[] @relation("approver")
  sharedTerritories SharedTerritory[]
  sharedTalks       SharedTalk[]
  apiTokens         TenantApiToken[]
  passkeys          TenantPasskey[]
}

model TenantAuth {
  id                  String    @id @default(uuid())
  tenantId            String    @unique
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  passwordHash        String
  totpSecret          String?
  totpEnabled         Boolean   @default(false)
  setupToken          String?   @unique
  setupTokenExpiresAt DateTime?
  failedAttempts      Int       @default(0)
  lockedUntil         DateTime?
  mfaCompleted        Boolean   @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model TenantApiToken {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  tokenHash String    // SHA-256 hash of plaintext token
  expiresAt DateTime  // 14 days from issuance
  rotatedAt DateTime? // last rotation timestamp
  revokedAt DateTime? // null = active
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([tenantId])
}

model TenantPasskey {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  credentialId Bytes    // WebAuthn credential ID
  publicKey    Bytes    // COSE public key
  counter      BigInt   @default(0)
  deviceType   String   // "singleDevice" | "multiDevice"
  backedUp     Boolean  @default(false)
  transports   String[] // ["usb", "ble", "nfc", "internal"]
  friendlyName String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([credentialId])
}

model SharingApproval {
  id          String   @id @default(uuid())
  requesterId String
  approverId  String
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  requester Tenant @relation("requester", fields: [requesterId], references: [id])
  approver  Tenant @relation("approver", fields: [approverId], references: [id])

  @@unique([requesterId, approverId])
}

model SharedTerritory {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model SharedTalk {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model TenantAuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  action    String   // e.g., "token_revealed", "login", "login_failed", "2fa_enabled", "2fa_disabled", "account_setup"
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}
