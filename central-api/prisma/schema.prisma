generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
}

model Tenant {
  id             String       @id @default(uuid())
  name           String
  email          String
  ownerFirstName String?
  ownerLastName  String?
  subdomain      String       @unique
  status       TenantStatus @default(PENDING)
  role         String       @default("owner") // owner | operator | readonly
  rejectReason String?
  tunnelId     String?
  tunnelToken  String?
  ztAppId      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  activatedAt  DateTime?

  auth              TenantAuth?
  sharingApprovals  SharingApproval[] @relation("requester")
  sharingApprovedBy SharingApproval[] @relation("approver")
  sharedTerritories SharedTerritory[]
  sharedTalks       SharedTalk[]
  sharedSpeakers    SharedSpeaker[]
  apiTokens         TenantApiToken[]
  setupCodes        SetupCode[]
  devices           TenantDevice[]
}

model TenantAuth {
  id              String    @id @default(uuid())
  tenantId        String    @unique
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  keycloakUserId  String?
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TenantApiToken {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  tokenHash String    // SHA-256 hash of plaintext token
  expiresAt DateTime  // 14 days from issuance
  rotatedAt DateTime? // last rotation timestamp
  revokedAt DateTime? // null = active
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([tenantId])
}

enum SharingStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

model SharingApproval {
  id                    String        @id @default(uuid())
  requesterId           String
  approverId            String
  status                SharingStatus @default(PENDING)

  // What the requester offers to share (JSON array: ["speakers","territories"])
  offeredCategories     Json          @default("[\"speakers\",\"territories\"]")
  // What the approver accepts (subset of offered, set on approval)
  acceptedCategories    Json?

  // Contact snapshot of the person who initiated the request
  requesterContactName  String?
  requesterContactEmail String?
  message               String?

  // Terms & response
  termsAcceptedAt       DateTime?
  termsVersion          String?
  rejectedReason        String?
  respondedAt           DateTime?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  requester Tenant @relation("requester", fields: [requesterId], references: [id])
  approver  Tenant @relation("approver", fields: [approverId], references: [id])

  @@unique([requesterId, approverId])
}

model SharedTerritory {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model SharedTalk {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

/// Visiting speakers shared by a tenant for partner congregations to browse/invite.
/// Only speakers with privilege:publicTalkVisiting are pushed here.
model SharedSpeaker {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json     /// Array of { name, talks[], sharePhone?, shareEmail?, shareAvailability?, monthlyInviteCap }
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model SetupCode {
  id         String    @id @default(uuid())
  code       String    @unique
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  expiresAt  DateTime
  consumedAt DateTime?
  consumedIp String?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

model TenantDevice {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  deviceCode String    @unique // ABCD-1234
  hostname   String
  os         String
  arch       String
  ip         String
  status     String    @default("pending") // pending | approved | denied | expired
  expiresAt  DateTime  // 15 minutes from creation
  approvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@index([deviceCode])
}

model TenantAuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  action    String   // e.g., "token_revealed", "login", "login_failed", "2fa_enabled", "2fa_disabled", "account_setup"
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}
