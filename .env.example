# hubport.cloud — Environment Variables
# Copy to .env and fill in values from your signup email

# Tenant ID (from signup email)
TENANT_ID=

# Database password (generate a strong password)
DB_PASSWORD=

# Keycloak admin credentials
KC_ADMIN=admin
KC_ADMIN_PASSWORD=

# Cloudflare Tunnel token (from signup email)
CF_TUNNEL_TOKEN=

# Optional: pin a specific version (default: latest)
# HUBPORT_VERSION=2026.03.18.1
