generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────

/// Base congregation role — what you ARE (with inheritance).
/// publisher ← ministerial_servant (separate branch)
/// publisher ← elder (separate branch)
/// An elder IS a publisher but is NOT a ministerial servant.
enum CongregationRole {
  publisher
  ministerial_servant
  elder
}

/// Member lifecycle status
enum MemberStatus {
  invited
  pending_approval
  active
  inactive
  rejected
}

enum Gender {
  male
  female
}

/// Privacy visibility level for publisher data
enum PrivacyVisibility {
  everyone
  elders_only
  nobody
}

/// Scope for app roles (which meeting types they apply to)
enum RoleScope {
  all
  midweek
  weekend
}

enum OnboardingStep {
  invited
  code_redeemed
  user_info
  security
  privacy
  complete
}

/// Meeting planning status lifecycle
enum PlanningStatus {
  draft
  open
  published
  locked
  archived
}

/// Meeting-level status
enum MeetingStatus {
  draft
  published
  locked
}

/// Assignment source — how the assignment was created
enum AssignmentSource {
  auto_seeded
  manual
  imported
}

/// Assignment status
enum AssignmentStatus {
  pending
  assigned
  confirmed
  declined
  cancelled
  substituted
}

/// Public talk schedule mode
enum TalkMode {
  local
  incoming_guest
  outgoing_guest
}

/// Public talk invitation state
enum InvitationState {
  draft
  invited
  confirmed
  declined
  cancelled
}

/// Speaker status
enum SpeakerStatus {
  active
  inactive
}

/// Workbook part section
enum WorkbookSection {
  treasures // Schätze aus Gottes Wort
  ministry // Uns im Dienst verbessern
  living // Unser Leben als Christ
}

/// Meeting slot category
enum SlotCategory {
  program // Program part (content)
  duty // Operational duty (sound, video, etc.)
}

// ─── Publisher ────────────────────────────────────────────────────────

model Publisher {
  id                String           @id @default(uuid())
  keycloakSub       String?          @unique /// Keycloak user ID link
  firstName         String /// @encrypted — AES-256-GCM
  lastName          String /// @encrypted — AES-256-GCM
  displayName       String? /// Optional display name override
  email             String? /// @encrypted — AES-256-GCM (private/contact email)
  internalEmail     String? /// Auto-generated username@slug.hubport.cloud (Matrix/Keycloak login)
  phone             String? /// @encrypted — AES-256-GCM
  gender            Gender?
  address           String? /// @encrypted — AES-256-GCM
  dateOfBirth       DateTime? /// @encrypted
  congregationRole  CongregationRole @default(publisher)
  congregationFlags String[] /// Additional flags: pioneer types, elder/MS sub-roles
  role              String           @default("publisher") /// Legacy Keycloak realm role (admin/elder/publisher/viewer)
  status            MemberStatus     @default(active)
  isOwner           Boolean          @default(false) /// Tenant owner (installer-created admin)
  notes             String? /// @encrypted — AES-256-GCM
  avatarUrl         String? /// Profile picture URL

  // Privacy
  privacyAccepted      Boolean   @default(false)
  privacyAcceptedAt    DateTime?
  privacySettings      Json      @default("{\"contactVisibility\":\"elders_only\",\"addressVisibility\":\"elders_only\",\"notesVisibility\":\"elders_only\"}")
  allowLocationSharing Boolean   @default(false) /// Opt-in for live location sharing during field service

  // Onboarding tracking
  invitedBy       String?
  invitedAt       DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  onboardingStep  OnboardingStep @default(invited)
  onboardingToken String? /// Hashed JWT — cleared on completion
  termsVersion    String? /// Version of accepted terms

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  syncVersion Int       @default(0)
  deletedAt   DateTime?

  // Relations
  assignments     TerritoryAssignment[]
  appRoles        AppRoleMember[]
  inviteCode      InviteCode?
  serviceGroup    ServiceGroup?         @relation(fields: [serviceGroupId], references: [id])
  serviceGroupId  String?
  overseerOf      ServiceGroup[]        @relation("ServiceGroupOverseer")
  assistantOf     ServiceGroup[]        @relation("ServiceGroupAssistant")
  gardenDuties    GardenDutyMember[]
  campaignInvites CampaignInvite[]
  assignedParts   MeetingAssignment[]   @relation("AssignedParts")
  assistedParts   MeetingAssignment[]   @relation("AssistedParts")
  awayPeriods     AwayPeriod[]
  speaker         Speaker?              @relation("PublisherSpeaker")
  notifications   Notification[]
  addressVisits   AddressVisit[]
  locationShares  LocationShare[]
}

// ─── App Roles (Permission Bundles) ──────────────────────────────────

model AppRole {
  id          String    @id @default(uuid())
  name        String    @unique /// e.g. "Coordinator", "Secretary"
  description String?
  permissions Json /// Array of permission keys ["app:publishers.view", ...]
  scope       RoleScope @default(all)
  isSystem    Boolean   @default(false) /// System roles cannot be deleted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members AppRoleMember[]
}

model AppRoleMember {
  id                String    @id @default(uuid())
  roleId            String
  publisherId       String
  validFrom         DateTime? /// Temporal validity (e.g. Circuit Overseer visit)
  validTo           DateTime?
  deniedPermissions Json      @default("[]") /// Per-assignment deny overrides

  role      AppRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@unique([roleId, publisherId])
  @@index([publisherId])
}

// ─── Audit Log ───────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String /// Keycloak sub of the actor
  action      String /// e.g. "publisher.update", "role.assign"
  objectType  String /// e.g. "Publisher", "AppRole"
  objectId    String?
  beforeState Json? /// Snapshot before mutation
  afterState  Json? /// Snapshot after mutation
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([objectType, objectId])
  @@index([createdAt])
}

// ─── Invite Codes ────────────────────────────────────────────────────

model InviteCode {
  id          String    @id @default(uuid())
  codeHash    String    @unique /// SHA-256 of the invite code
  publisherId String    @unique
  expiresAt   DateTime
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())

  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
}

// ─── Existing Models ─────────────────────────────────────────────────

model Territory {
  id            String    @id @default(uuid())
  number        String    @unique
  name          String
  description   String?
  type          String    @default("territory") // "territory" | "congregation_boundary"
  boundaries    Json? // GeoJSON for map display
  shareExcluded Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  syncVersion   Int       @default(0)
  deletedAt     DateTime?

  assignments      TerritoryAssignment[]
  addresses        Address[]
  osmFeatures      LocalOsmFeature[]
  ignoredBuildings IgnoredOsmBuilding[]
  osmRefreshJobs   OsmRefreshQueue[]
  gapDetectionRuns GapDetectionRun[]
  shares           TerritoryShare[]
  boundaryVersions TerritoryBoundaryVersion[]
}

model TerritoryBoundaryVersion {
  id            String   @id @default(uuid())
  territoryId   String
  version       Int
  boundaries    Json
  changeType    String // "creation" | "manual_edit" | "auto_clip" | "import" | "restore"
  changeSummary String?
  createdAt     DateTime @default(now())

  territory Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@index([territoryId, version])
}

model TerritoryAssignment {
  id          String    @id @default(uuid())
  territoryId String
  publisherId String
  assignedAt  DateTime  @default(now())
  assignedBy  String? /// publisherId who assigned
  returnedAt  DateTime?
  returnedBy  String? /// publisherId who returned it
  dueDate     DateTime? /// Adaptive due date
  isActive    Boolean   @default(true)
  campaignId  String?
  isSuspended Boolean   @default(false)
  groupId     String? /// field group ID (deliberately unlinked)
  notes       String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  syncVersion Int       @default(0)
  deletedAt   DateTime?

  territory Territory @relation(fields: [territoryId], references: [id])
  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@index([territoryId, isActive])
  @@index([publisherId, isActive])
}

model Meeting {
  id        String        @id @default(uuid())
  title     String
  type      String // midweek, weekend, special
  date      DateTime
  startTime String // "19:00"
  endTime   String? // "21:00"
  location  String?
  notes     String?
  status    MeetingStatus @default(draft)

  // Planning linkage
  meetingPeriodId    String?
  workbookWeekId     String?
  weekendStudyWeekId String?
  publishedAt        DateTime?
  publishedBy        String? /// keycloakSub of publisher

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  meetingPeriod    MeetingPeriod?       @relation(fields: [meetingPeriodId], references: [id])
  workbookWeek     WorkbookWeek?        @relation(fields: [workbookWeekId], references: [id])
  weekendStudyWeek WeekendStudyWeek?    @relation(fields: [weekendStudyWeekId], references: [id])
  assignments      MeetingAssignment[]
  talkSchedules    PublicTalkSchedule[]

  @@index([date])
  @@index([meetingPeriodId])
  @@index([type, date])
}

// ─── Congregation Settings ──────────────────────────────────────────

model CongregationSettings {
  id                      String   @id @default(uuid())
  language                String   @default("de") /// Congregation language (ISO 639-1)
  jwLanguageCode          String   @default("de") /// JW.org language code
  defaultMidweekDay       Int      @default(3) /// 0=Sun, 1=Mon, ... 3=Wed
  defaultMidweekTime      String   @default("19:00")
  defaultWeekendDay       Int      @default(0) /// 0=Sun
  defaultWeekendTime      String   @default("10:00")
  defaultLocation         String?
  // Territory module settings
  defaultCheckoutDays     Int      @default(120)
  overdueReminderDays     Int      @default(14)
  returnedVisibleDays     Int      @default(30)
  osmRefreshCooldownHours Int      @default(24)
  gapDetectionMinArea     Int      @default(50)
  defaultShareScope       String   @default("boundary")
  defaultShareDays        Int      @default(30)
  shareMaxDays            Int      @default(90)
  autoSyncTerritories     Boolean  @default(false)
  requirePINForFullShare  Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ─── Meeting Periods ────────────────────────────────────────────────

model MeetingPeriod {
  id              String         @id @default(uuid())
  type            String // midweek_workbook, weekend_study
  status          PlanningStatus @default(draft)
  language        String
  startDate       DateTime
  endDate         DateTime
  sourceEditionId String? /// WorkbookEdition or WeekendStudyEdition id
  openedBy        String? /// keycloakSub
  openedAt        DateTime?
  publishedBy     String?
  publishedAt     DateTime?
  lockedBy        String?
  lockedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  meetings Meeting[]

  @@index([type, status])
  @@index([startDate, endDate])
}

// ─── Workbook Import ────────────────────────────────────────────────

model WorkbookEdition {
  id                    String   @id @default(uuid())
  language              String
  yearMonth             String /// e.g. "2026-03", "2026-04"
  sourceUrl             String?
  sourcePublicationCode String? /// e.g. "mwb"
  checksum              String? /// SHA-256 of source content
  rawMetadata           Json? /// Raw import metadata for debugging
  importedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  weeks WorkbookWeek[]

  @@unique([language, yearMonth])
  @@index([language])
}

model WorkbookWeek {
  id           String   @id @default(uuid())
  editionId    String
  weekOf       DateTime /// Monday of the week
  dateRange    String? /// e.g. "March 23–29"
  theme        String? /// Main scripture/theme
  bibleReading String? /// Bible reading reference
  songNumbers  Int[] /// Song numbers for the week [opening, middle, closing]
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  edition  WorkbookEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  parts    WorkbookPart[]
  meetings Meeting[]

  @@unique([editionId, weekOf])
  @@index([editionId])
  @@index([weekOf])
}

model WorkbookPart {
  id                String          @id @default(uuid())
  weekId            String
  section           WorkbookSection
  partType          String /// Normalized type: "talk", "bible_reading", "initial_call", etc.
  title             String /// Part title from workbook
  durationMinutes   Int?
  sourceRef         String? /// Reference to source material
  sourceUrl         String?
  requiresAssistant Boolean         @default(false)
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  week        WorkbookWeek        @relation(fields: [weekId], references: [id], onDelete: Cascade)
  assignments MeetingAssignment[]

  @@index([weekId])
  @@index([section])
}

// ─── Weekend Study Import ───────────────────────────────────────────

model WeekendStudyEdition {
  id          String   @id @default(uuid())
  language    String
  issueKey    String /// e.g. "w_2026_03"
  checksum    String?
  rawMetadata Json?
  importedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weeks WeekendStudyWeek[]

  @@unique([language, issueKey])
}

model WeekendStudyWeek {
  id           String   @id @default(uuid())
  editionId    String
  weekOf       DateTime /// Sunday of the study week
  articleTitle String
  articleUrl   String?
  studyNumber  Int? /// Study article number (e.g., 1, 2, 3...)
  sourceRef    String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  edition  WeekendStudyEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  meetings Meeting[]

  @@unique([editionId, weekOf])
  @@index([editionId])
  @@index([weekOf])
}

// ─── Meeting Slot Templates ─────────────────────────────────────────

model MeetingSlotTemplate {
  id                 String       @id @default(uuid())
  meetingType        String // midweek, weekend, all
  slotKey            String       @unique /// e.g. "chairman_midweek", "sound", "opening_prayer"
  label              String /// Human-readable label
  category           SlotCategory @default(program)
  requiredPrivileges String[] /// Permission keys required to fill this slot
  allowsAssistant    Boolean      @default(false)
  requiresAssistant  Boolean      @default(false)
  sortOrder          Int          @default(0)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  assignments MeetingAssignment[]

  @@index([meetingType])
}

// ─── Meeting Assignments ────────────────────────────────────────────

model MeetingAssignment {
  id                   String           @id @default(uuid())
  meetingId            String
  slotTemplateId       String
  workbookPartId       String? /// Links to specific workbook part (midweek)
  assigneePublisherId  String? /// Assigned publisher
  assistantPublisherId String? /// Assistant/householder
  status               AssignmentStatus @default(pending)
  source               AssignmentSource @default(manual)
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  meeting      Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  slotTemplate MeetingSlotTemplate @relation(fields: [slotTemplateId], references: [id])
  workbookPart WorkbookPart?       @relation(fields: [workbookPartId], references: [id], onDelete: SetNull)
  assignee     Publisher?          @relation("AssignedParts", fields: [assigneePublisherId], references: [id], onDelete: SetNull)
  assistant    Publisher?          @relation("AssistedParts", fields: [assistantPublisherId], references: [id], onDelete: SetNull)

  @@unique([meetingId, slotTemplateId, workbookPartId])
  @@index([meetingId])
  @@index([assigneePublisherId])
  @@index([assistantPublisherId])
}

// ─── Assignment History (Immutable Audit) ───────────────────────────

model AssignmentHistory {
  id            String   @id @default(uuid())
  assignmentId  String
  action        String /// create, update, unassign, substitute, publish, lock, reopen
  actorId       String /// keycloakSub
  previousState Json?
  newState      Json?
  reason        String?
  createdAt     DateTime @default(now())

  @@index([assignmentId])
  @@index([actorId])
  @@index([createdAt])
}

// ─── Speakers & Public Talks ────────────────────────────────────────

model Speaker {
  id                String        @id @default(uuid())
  firstName         String /// @encrypted
  lastName          String /// @encrypted
  congregationName  String? /// Source congregation name (encrypted for manual speakers)
  email             String? /// @encrypted — contact email
  phone             String? /// @encrypted — contact phone
  publisherId       String?       @unique /// FK to Publisher — set for local speakers, null for manual/hubport
  publisher         Publisher?    @relation("PublisherSpeaker", fields: [publisherId], references: [id], onDelete: SetNull)
  source            SpeakerSource @default(local)
  isLocal           Boolean       @default(true) /// @deprecated — use source enum. Kept for migration.
  status            SpeakerStatus @default(active)
  monthlyInviteCap  Int           @default(4) /// Max talks per month (speaker sets in profile)
  sharePhone        Boolean       @default(false) /// Privacy: share phone with partners
  shareEmail        Boolean       @default(false) /// Privacy: share email with partners
  shareAvailability Boolean       @default(true) /// Privacy: share availability with partners
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  schedules PublicTalkSchedule[]
  talks     SpeakerTalk[]

  @@index([source, status])
}

enum SpeakerSource {
  local /// Own congregation publisher
  hubport /// From hubport.cloud partner (federated)
  manual /// Manually added (not on hubport.cloud)
}

model PublicTalk {
  id           String   @id @default(uuid())
  talkNumber   Int      @unique /// Official talk number
  title        String
  outline      String? /// Optional outline/description
  discontinued Boolean  @default(false) /// true = no longer in active catalog
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schedules PublicTalkSchedule[]
  speakers  SpeakerTalk[]
}

model SpeakerTalk {
  id           String     @id @default(uuid())
  speakerId    String
  speaker      Speaker    @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  publicTalkId String
  publicTalk   PublicTalk @relation(fields: [publicTalkId], references: [id], onDelete: Cascade)
  muted        Boolean    @default(false) /// Speaker can temporarily mute a talk (not available for scheduling)

  @@unique([speakerId, publicTalkId])
  @@index([speakerId])
  @@index([publicTalkId])
}

model AwayPeriod {
  id          String    @id @default(uuid())
  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  reason      String? /// @encrypted — AES-256-GCM
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([publisherId, startDate, endDate])
  @@index([publisherId])
  @@index([startDate, endDate])
}

model PublicTalkSchedule {
  id                  String          @id @default(uuid())
  meetingId           String
  speakerId           String
  publicTalkId        String?
  mode                TalkMode        @default(local)
  invitationState     InvitationState @default(draft)
  invitedAt           DateTime?
  confirmedAt         DateTime?
  declinedAt          DateTime?
  cancelledAt         DateTime?
  notes               String?
  centralInvitationId String? /// Links to central-api TalkInvitation for cross-tenant invites
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  meeting    Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speaker    Speaker     @relation(fields: [speakerId], references: [id])
  publicTalk PublicTalk? @relation(fields: [publicTalkId], references: [id])

  @@unique([meetingId, speakerId])
  @@index([meetingId])
  @@index([speakerId])
  @@index([invitationState])
}

// ─── Service Groups ─────────────────────────────────────────────────

/// Field service groups — publishers are assigned to one group.
/// Default: 5 groups, configurable by admin.
model ServiceGroup {
  id          String   @id @default(uuid())
  name        String   @unique /// e.g. "Gruppe 1", "Gruppe 2"
  overseerId  String? /// FK to Publisher (group overseer)
  assistantId String? /// FK to Publisher (group assistant)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  overseerPub       Publisher?         @relation("ServiceGroupOverseer", fields: [overseerId], references: [id], onDelete: SetNull)
  assistantPub      Publisher?         @relation("ServiceGroupAssistant", fields: [assistantId], references: [id], onDelete: SetNull)
  members           Publisher[]
  cleaningSchedules CleaningSchedule[]
}

// ─── Cleaning & Garden ──────────────────────────────────────────────

enum CleaningCategory {
  grundreinigung
  sichtreinigung
  monatsreinigung
  custom
}

/// Cleaning duty types — assigned to SERVICE GROUPS on a rotating schedule.
/// Admin creates named types (e.g., "Penzberg Nord Grund").
model CleaningDuty {
  id        String           @id @default(uuid())
  name      String /// Free-text name (e.g. "Penzberg Nord Grund")
  category  CleaningCategory @default(custom)
  isDefault Boolean          @default(false) /// True for auto-created defaults
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  schedules CleaningSchedule[]
}

/// Cleaning schedule — maps a duty to a service group on a specific date.
model CleaningSchedule {
  id             String         @id @default(uuid())
  duty           CleaningDuty   @relation(fields: [dutyId], references: [id], onDelete: Cascade)
  dutyId         String
  serviceGroup   ServiceGroup   @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade)
  serviceGroupId String
  date           DateTime /// Scheduled date
  status         ScheduleStatus @default(scheduled)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([date])
  @@index([dutyId, date])
}

enum ScheduleStatus {
  scheduled
  completed
  skipped
}

enum GardenDutyType {
  rasen
  winterdienst
  custom
}

/// Garden duties — assigned to INDIVIDUAL PUBLISHERS (not service groups).
model GardenDuty {
  id        String         @id @default(uuid())
  name      String /// e.g. "Rasen mähen", "Winterdienst"
  type      GardenDutyType @default(custom)
  isDefault Boolean        @default(false)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  members GardenDutyMember[]
}

/// Publisher assignment to a garden duty.
model GardenDutyMember {
  id          String     @id @default(uuid())
  duty        GardenDuty @relation(fields: [dutyId], references: [id], onDelete: Cascade)
  dutyId      String
  publisher   Publisher  @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  publisherId String
  createdAt   DateTime   @default(now())

  @@unique([dutyId, publisherId])
  @@index([publisherId])
}

// ─── Chat ────────────────────────────────────────────────────────────

model ChatSettings {
  id           String   @id @default(uuid())
  dmsEnabled   Boolean  @default(true)
  callsEnabled Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

/// Persists provisioned Matrix space/room IDs for the tenant.
/// Used by matrix-provisioning.ts to ensure idempotent space creation.
model MatrixSpaceConfig {
  id        String   @id @default(uuid())
  spaceId   String /// Matrix room ID of the space
  spaceName String   @unique /// "Versammlung" or "Dienste"
  rooms     Json /// [{ roomId, name, requiredRole }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// In-app notifications (invitation status changes, etc.)
model Notification {
  id          String    @id @default(uuid())
  publisherId String
  type        String /// "invitation_received", "invitation_approved", etc.
  title       String
  body        String
  data        Json? /// { invitationId, partnerId, ... }
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@index([publisherId, readAt])
}

enum AddressType {
  residential
  business
  apartment_building
  rural
}

enum AddressStatus {
  active
  do_not_call
  not_at_home
  moved
  deceased
  foreign_language
  archived
}

enum AddressSource {
  manual
  osm
  csv_import
}

enum VisitOutcome {
  contacted
  not_at_home
  do_not_call
  moved
  letter_sent
  phone_attempted
}

enum LocalOsmType {
  building_override
  street
  poi
  custom
}

enum CampaignStatus {
  draft
  active
  closed
  archived
}

enum CampaignTemplate {
  gedaechtnismahl
  kongress
  predigtdienstaktion
  custom
}

enum FieldGroupStatus {
  open
  in_field
  closed
}

enum CampaignInviteStatus {
  pending
  accepted
  unavailable
}

model Campaign {
  id            String                 @id @default(uuid())
  title         String
  template      CampaignTemplate
  status        CampaignStatus         @default(draft)
  startDate     DateTime
  endDate       DateTime
  matrixRoomId  String?
  createdBy     String /// keycloakSub of creator
  invitations   CampaignInvite[]
  meetingPoints CampaignMeetingPoint[]
  createdAt     DateTime               @default(now())
  deletedAt     DateTime? /// auto-delete 7 days after endDate
}

model CampaignInvite {
  id          String               @id @default(uuid())
  campaign    Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId  String
  publisher   Publisher            @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  publisherId String
  status      CampaignInviteStatus @default(pending)
  respondedAt DateTime?

  @@unique([campaignId, publisherId])
  @@index([publisherId])
}

// ─── Campaign Meeting Points ────────────────────────────────────────

/// Meeting point within a campaign — links conductor, assistants, and territories.
/// Full model in Chunk 2; stub for policy engine dynamic permissions.
model CampaignMeetingPoint {
  id           String   @id @default(uuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  conductorId  String /// publisherId of conductor
  assistantIds String[] /// publisherIds of assistants
  territoryIds String[] /// territory IDs assigned to this meeting point
  name         String? /// Meeting point name/location
  latitude     Float?
  longitude    Float?
  address      String?
  dayOfWeek    String?
  time         String?
  createdAt    DateTime @default(now())

  syncVersion Int       @default(0)
  deletedAt   DateTime?

  fieldServiceMeetingPointId String? /// Optional link to permanent meeting point
  fieldServiceMeetingPoint   FieldServiceMeetingPoint? @relation(fields: [fieldServiceMeetingPointId], references: [id])

  fieldGroups CampaignFieldGroup[]

  @@index([campaignId])
  @@index([conductorId])
}

model CampaignFieldGroup {
  id             String               @id @default(uuid())
  meetingPointId String
  meetingPoint   CampaignMeetingPoint @relation(fields: [meetingPointId], references: [id], onDelete: Cascade)
  name           String?
  memberIds      String[] /// publisherIds
  territoryIds   String[] /// territory IDs (a group can work multiple territories)
  sessionDate    DateTime?            @db.Date
  sessionTime    String?
  status         FieldGroupStatus     @default(open)
  startedAt      DateTime?
  closedAt       DateTime?
  notes          String?
  joinCode       String? /// 6-char alphanumeric join code, unique while active
  createdAt      DateTime             @default(now())

  locationShares LocationShare[]

  @@index([meetingPointId])
}

enum LocationDuration {
  one_hour
  four_hours
  eight_hours
}

model LocationShare {
  id            String             @id @default(uuid())
  fieldGroupId  String
  fieldGroup    CampaignFieldGroup @relation(fields: [fieldGroupId], references: [id], onDelete: Cascade)
  publisherId   String
  publisher     Publisher          @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  lastLatitude  Float? /// Cleared on deactivation
  lastLongitude Float? /// Cleared on deactivation
  heading       Float? /// Compass heading in degrees (0-360)
  accuracy      Float? /// GPS accuracy in meters
  isActive      Boolean            @default(true)
  duration      LocationDuration
  consentedAt   DateTime           @default(now())
  lastUpdatedAt DateTime?
  expiresAt     DateTime /// Auto-expire after duration

  @@index([fieldGroupId, isActive])
  @@index([publisherId])
}

// ─── Field Service Module ──────────────────────────────────────────���─

enum ServiceMeetingStatus {
  planned
  active
  completed
  cancelled
}

enum ServiceFieldGroupStatus {
  planned
  in_field
  completed
}

/// Permanent, recurring meeting point for regular field service.
model FieldServiceMeetingPoint {
  id              String    @id @default(uuid())
  tenantId        String
  name            String
  address         String?
  latitude        Float?
  longitude       Float?
  dayOfWeek       Int /// 0=Sun, 1=Mon, ..., 6=Sat
  time            String /// "HH:MM" format
  conductorId     String? /// Default conductor (Publisher ID)
  assistantIds    String[] /// Default assistant Publisher IDs
  territoryIds    String[] /// Default territory IDs to work
  maxParticipants Int?
  isActive        Boolean   @default(true)
  notes           String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  syncVersion     Int       @default(0)
  deletedAt       DateTime?

  serviceMeetings       ServiceGroupMeeting[]
  campaignMeetingPoints CampaignMeetingPoint[]

  @@index([tenantId])
}

/// Concrete, scheduled instance of field service at a meeting point.
model ServiceGroupMeeting {
  id             String                   @id @default(uuid())
  tenantId       String
  meetingPointId String
  meetingPoint   FieldServiceMeetingPoint @relation(fields: [meetingPointId], references: [id], onDelete: Cascade)
  serviceGroupId String? /// Optional link to existing ServiceGroup
  campaignId     String? /// If set, this is a campaign-linked meeting
  date           DateTime /// Concrete date of meeting
  time           String /// "HH:MM" format
  conductorId    String /// Conductor for this meeting
  status         ServiceMeetingStatus     @default(planned)
  notes          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdBy      String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  syncVersion    Int                      @default(0)
  deletedAt      DateTime?

  signups     ServiceMeetingSignup[]
  fieldGroups ServiceMeetingFieldGroup[]

  @@index([tenantId])
  @@index([meetingPointId])
  @@index([date])
}

/// Publisher self-enrollment for a service meeting.
model ServiceMeetingSignup {
  id          String              @id @default(uuid())
  tenantId    String
  meetingId   String
  meeting     ServiceGroupMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  publisherId String
  signedUpAt  DateTime            @default(now())
  cancelledAt DateTime?

  @@unique([meetingId, publisherId])
  @@index([publisherId])
}

/// Sub-group within a service meeting — conductor organizes publishers into groups.
model ServiceMeetingFieldGroup {
  id           String                  @id @default(uuid())
  tenantId     String
  meetingId    String
  meeting      ServiceGroupMeeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name         String? /// "Gruppe 1", "Gruppe 2"
  leaderId     String /// Group leader Publisher ID
  memberIds    String[] /// Publisher IDs in this group
  territoryIds String[] /// Assigned territory IDs
  status       ServiceFieldGroupStatus @default(planned)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  locationShares ServiceLocationShare[]

  @@index([meetingId])
}

/// Real-time location sharing during field service. Opt-in only.
model ServiceLocationShare {
  id            String                   @id @default(uuid())
  tenantId      String
  fieldGroupId  String
  fieldGroup    ServiceMeetingFieldGroup @relation(fields: [fieldGroupId], references: [id], onDelete: Cascade)
  publisherId   String
  latitude      Float
  longitude     Float
  accuracy      Float? /// GPS accuracy in meters
  isActive      Boolean                  @default(true)
  startedAt     DateTime                 @default(now())
  lastUpdatedAt DateTime                 @default(now())
  stoppedAt     DateTime?

  @@index([fieldGroupId, isActive])
  @@index([publisherId])
}

// ─── Sharing Visibility RBAC ──────────────────────────────────────────

/// Controls which roles in THIS congregation can see shared data from each partner.
/// Defaults: territories/talks → publisher, speakers → elder
model SharingVisibility {
  id        String   @id @default(uuid())
  partnerId String // The sharing partner's tenantId (from central-api)
  category  String // "speakers" | "territories"
  minRole   String // "enabled" | "disabled"
  depth     String   @default("boundary") /// "boundary" | "addresses" | "full"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partnerId, category])
}

// ─── Territory Sharing ──────────────────────────────────────────────

model TerritoryShare {
  id          String    @id @default(uuid())
  territoryId String
  territory   Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  codeHash    String    @unique /// SHA-256 of share code
  scope       String    @default("boundary") /// "boundary" | "addresses" | "full"
  pinHash     String? /// SHA-256 hash of PIN (required for scope=full)
  pinAttempts Int       @default(0)
  expiresAt   DateTime
  revokedAt   DateTime?
  revokedBy   String? /// publisherId
  isActive    Boolean   @default(true)
  createdBy   String /// publisherId
  createdAt   DateTime  @default(now())
  syncVersion Int       @default(0)
  deletedAt   DateTime?

  accessLogs ShareAccessLog[]

  @@index([territoryId])
  @@index([isActive, expiresAt])
}

model ShareAccessLog {
  id        String         @id @default(uuid())
  shareId   String
  share     TerritoryShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  ipHash    String /// SHA-256 of IP
  userAgent String?
  scope     String /// What was actually viewed
  createdAt DateTime       @default(now())

  @@index([shareId])
  @@index([createdAt])
}

// ─── Territory Addresses & OSM ──────────────────────────────────────

model Address {
  id              String        @id @default(uuid())
  territoryId     String
  territory       Territory     @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  osmId           String? /// OSM node/way ID
  lat             Float
  lng             Float
  // point column added via raw SQL (PostGIS)
  street          String?
  houseNumber     String?
  city            String?
  postcode        String?
  buildingType    String? /// e.g. "apartments", "house", "yes"
  units           Int           @default(1)
  bellCount       Int           @default(1) /// Number of doorbells/units
  floor           String?
  type            AddressType   @default(residential)
  status          AddressStatus @default(active)
  source          AddressSource @default(manual)
  languages       String[] /// ISO 639-1 codes spoken here
  doNotCallReason String? /// Reason for DNC status
  doNotVisitUntil DateTime? /// Temporary DNC expiry
  notes           String?
  lastVisitAt     DateTime?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  syncVersion     Int           @default(0)
  deletedAt       DateTime?

  visits AddressVisit[]

  @@index([territoryId])
  @@index([osmId])
  @@index([status])
}

model AddressVisit {
  id          String       @id @default(uuid())
  addressId   String
  address     Address      @relation(fields: [addressId], references: [id], onDelete: Cascade)
  publisherId String
  publisher   Publisher    @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  outcome     VisitOutcome
  notes       String?
  visitedAt   DateTime     @default(now())
  syncVersion Int          @default(0)
  deletedAt   DateTime?

  @@index([addressId])
  @@index([publisherId])
  @@index([visitedAt])
}

model LocalOsmFeature {
  id           String       @id @default(uuid())
  territoryId  String
  territory    Territory    @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  osmId        String? /// Nullable for user-created features
  featureType  LocalOsmType
  tags         Json /// Raw OSM tags
  geometry     Json /// GeoJSON geometry
  enrichedName String? /// Manual name override
  enrichedType String? /// Manual type override
  createdBy    String? /// publisherId
  updatedBy    String? /// publisherId
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([territoryId, osmId])
  @@index([territoryId])
}

model IgnoredOsmBuilding {
  id            String    @id @default(uuid())
  territoryId   String
  territory     Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  osmId         String
  reason        String /// Required reason for ignoring
  notes         String?
  evidence      String? /// What evidence prompted the ignore
  lat           Float?
  lng           Float?
  streetAddress String?
  buildingType  String?
  ignoredBy     String /// publisherId
  createdAt     DateTime  @default(now())

  @@unique([territoryId, osmId])
}

model BuildingOverride {
  id                String    @id @default(uuid())
  osmId             String    @unique
  overriddenType    String?
  overriddenAddress String?
  triageStatus      String    @default("unreviewed") /// unreviewed, confirmed_residential, ignored, needs_visit
  notes             String?
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model OsmRefreshQueue {
  id               String    @id @default(uuid())
  territoryId      String
  territory        Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  status           String    @default("pending") /// pending, processing, completed, failed
  startedAt        DateTime?
  completedAt      DateTime?
  error            String?
  buildingsFound   Int?
  addressesCreated Int?
  addressesUpdated Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([territoryId])
  @@index([status])
}

model GapDetectionRun {
  id             String    @id @default(uuid())
  territoryId    String
  territory      Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  status         String    @default("pending") /// pending, running, completed, failed
  totalBuildings Int?
  coveredCount   Int?
  gapCount       Int?
  resultGeoJson  Json? /// GeoJSON of uncovered areas
  startedAt      DateTime?
  completedAt    DateTime?
  runBy          String /// publisherId
  createdAt      DateTime  @default(now())

  @@index([territoryId])
}

// ═══════════════════════════════════════════════════════════════════
// Central-API owned tables — @@ignore prevents hub-api db push from
// dropping them. These stubs MUST stay in sync with central-api/prisma/schema.prisma.
// See incident history in hubport-deploy skill (#241, #244).
// ═══════════════════════════════════════════════════════════════════

enum TenantStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
}

enum SharingStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

model Tenant {
  id             String       @id @default(uuid())
  name           String
  email          String
  ownerFirstName String?
  ownerLastName  String?
  subdomain      String       @unique
  status         TenantStatus @default(PENDING)
  role           String       @default("owner")
  rejectReason   String?
  tunnelId       String?
  tunnelToken    String?
  ztAppId        String?
  discoverable   Boolean      @default(false)
  centroidLat    Float?
  centroidLng    Float?
  circuitNumber  String?
  region         String?
  country        String?
  city           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  activatedAt    DateTime?

  @@ignore
}

model TenantAuth {
  id             String    @id @default(uuid())
  tenantId       String    @unique
  keycloakUserId String?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@ignore
}

model TenantApiToken {
  id        String    @id @default(uuid())
  tenantId  String
  tokenHash String
  expiresAt DateTime
  rotatedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([tenantId])
  @@ignore
}

model SharingApproval {
  id                    String        @id @default(uuid())
  requesterId           String
  approverId            String
  status                SharingStatus @default(PENDING)
  offeredCategories     Json          @default("[\"speakers\",\"territories\"]")
  acceptedCategories    Json?
  requesterContactName  String?
  requesterContactEmail String?
  message               String?
  termsAcceptedAt       DateTime?
  termsVersion          String?
  rejectedReason        String?
  respondedAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([requesterId, approverId])
  @@ignore
}

// ─── Device Registration & Push Subscriptions ───────────────────────

model Device {
  id           String    @id @default(uuid())
  tenantId     String
  userId       String
  deviceUuid   String
  userAgent    String
  platform     String
  screenSize   String
  displayName  String
  encSalt      String
  status       String    @default("active")
  revokedAt    DateTime?
  revokedBy    String?
  revokeReason String?
  lastSyncAt   DateTime?
  lastIp       String?
  registeredAt DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pushSubscription PushSubscription?

  @@unique([userId, deviceUuid])
  @@index([tenantId, userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  tenantId  String
  deviceId  String   @unique
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SharedTerritory {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json
  syncedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@ignore
}

model SharedTalk {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json
  updatedAt DateTime @updatedAt

  @@ignore
}

model SharedSpeaker {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json
  updatedAt DateTime @updatedAt

  @@ignore
}

model SetupCode {
  id         String    @id @default(uuid())
  code       String    @unique
  tenantId   String
  expiresAt  DateTime
  consumedAt DateTime?
  consumedIp String?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@ignore
}

model TenantDevice {
  id         String    @id @default(uuid())
  tenantId   String
  deviceCode String    @unique
  hostname   String
  os         String
  arch       String
  ip         String
  status     String    @default("pending")
  expiresAt  DateTime
  approvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@index([deviceCode])
  @@ignore
}

model TenantAuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  action    String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@ignore
}
