generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────

/// Base congregation role — what you ARE (with inheritance).
/// publisher ← ministerial_servant (separate branch)
/// publisher ← elder (separate branch)
/// An elder IS a publisher but is NOT a ministerial servant.
enum CongregationRole {
  publisher
  ministerial_servant
  elder
}

/// Member lifecycle status
enum MemberStatus {
  invited
  pending_approval
  active
  inactive
  rejected
}

enum Gender {
  male
  female
}

/// Privacy visibility level for publisher data
enum PrivacyVisibility {
  everyone
  elders_only
  nobody
}

/// Scope for app roles (which meeting types they apply to)
enum RoleScope {
  all
  midweek
  weekend
}

// ─── Publisher ────────────────────────────────────────────────────────

model Publisher {
  id               String            @id @default(uuid())
  keycloakSub      String?           @unique /// Keycloak user ID link
  firstName        String            /// @encrypted — AES-256-GCM
  lastName         String            /// @encrypted — AES-256-GCM
  displayName      String?           /// Optional display name override
  email            String?           /// @encrypted — AES-256-GCM
  phone            String?           /// @encrypted — AES-256-GCM
  gender           Gender?
  address          String?           /// @encrypted — AES-256-GCM
  dateOfBirth      DateTime?         /// @encrypted
  congregationRole CongregationRole  @default(publisher)
  congregationFlags String[]         /// Additional flags: pioneer types, elder/MS sub-roles
  role             String            @default("publisher") /// Legacy Keycloak realm role (admin/elder/publisher/viewer)
  status           MemberStatus      @default(active)
  notes            String?           /// @encrypted — AES-256-GCM
  avatarUrl        String?           /// Profile picture URL

  // Privacy
  privacyAccepted   Boolean          @default(false)
  privacyAcceptedAt DateTime?
  privacySettings   Json             @default("{\"contactVisibility\":\"elders_only\",\"addressVisibility\":\"elders_only\",\"notesVisibility\":\"elders_only\"}")

  // Onboarding tracking
  invitedBy  String?
  invitedAt  DateTime?
  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assignments     TerritoryAssignment[]
  appRoles        AppRoleMember[]
  inviteCode      InviteCode?
  serviceGroup    ServiceGroup?       @relation(fields: [serviceGroupId], references: [id])
  serviceGroupId  String?
  gardenDuties       GardenDutyMember[]
  campaignInvites    CampaignInvite[]
}

// ─── App Roles (Permission Bundles) ──────────────────────────────────

model AppRole {
  id          String    @id @default(uuid())
  name        String    @unique /// e.g. "Coordinator", "Secretary"
  description String?
  permissions Json      /// Array of permission keys ["app:publishers.view", ...]
  scope       RoleScope @default(all)
  isSystem    Boolean   @default(false) /// System roles cannot be deleted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members AppRoleMember[]
}

model AppRoleMember {
  id                String    @id @default(uuid())
  roleId            String
  publisherId       String
  validFrom         DateTime? /// Temporal validity (e.g. Circuit Overseer visit)
  validTo           DateTime?
  deniedPermissions Json      @default("[]") /// Per-assignment deny overrides

  role      AppRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@unique([roleId, publisherId])
  @@index([publisherId])
}

// ─── Audit Log ───────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String   /// Keycloak sub of the actor
  action      String   /// e.g. "publisher.update", "role.assign"
  objectType  String   /// e.g. "Publisher", "AppRole"
  objectId    String?
  beforeState Json?    /// Snapshot before mutation
  afterState  Json?    /// Snapshot after mutation
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([objectType, objectId])
  @@index([createdAt])
}

// ─── Invite Codes ────────────────────────────────────────────────────

model InviteCode {
  id          String    @id @default(uuid())
  codeHash    String    @unique /// SHA-256 of the invite code
  publisherId String    @unique
  expiresAt   DateTime
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())

  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
}

// ─── Existing Models ─────────────────────────────────────────────────

model Territory {
  id          String   @id @default(uuid())
  number      String   @unique
  name        String
  description String?
  boundaries  Json? // GeoJSON for map display
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments TerritoryAssignment[]
}

model TerritoryAssignment {
  id          String    @id @default(uuid())
  territoryId String
  publisherId String
  assignedAt  DateTime  @default(now())
  returnedAt  DateTime?

  territory Territory @relation(fields: [territoryId], references: [id])
  publisher Publisher @relation(fields: [publisherId], references: [id])

  @@index([territoryId])
  @@index([publisherId])
}

model Meeting {
  id        String   @id @default(uuid())
  title     String
  type      String // midweek, weekend, special
  date      DateTime
  startTime String // "19:00"
  endTime   String? // "21:00"
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Security (ADR-0077) ──────────────────────────────────────────────

/// WebAuthn passkey credentials — stored in our DB, not Keycloak.
/// Keycloak 24 Admin API doesn't support reliable WebAuthn CRUD.
model WebAuthnCredential {
  id           String   @id @default(cuid())
  keycloakSub  String   /// Keycloak user ID (sub claim)
  credentialId String   @unique /// Base64url-encoded credential ID from browser
  publicKey    Bytes    /// COSE public key
  counter      BigInt   @default(0) /// Signature counter for clone detection
  deviceType   String   @default("platform") /// "platform" or "cross-platform"
  backedUp     Boolean  @default(false) /// Whether credential is backed up
  transports   String[] /// e.g., ["internal", "hybrid"]
  label        String   @default("Passkey") /// User-facing name
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  @@index([keycloakSub])
  @@map("webauthn_credentials")
}

/// Tracks security setup completion per user.
/// passwordChanged flag avoids relying on Keycloak credential timestamps.
model SecuritySetup {
  id                String    @id @default(cuid())
  keycloakSub       String    @unique /// Keycloak user ID
  passwordChanged   Boolean   @default(false)
  passwordChangedAt DateTime?
  totpSecret        String?   /// TOTP secret (base32) — stored here for reliable verification
  totpEnabledAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("security_setup")
}

// ─── Service Groups ─────────────────────────────────────────────────

/// Field service groups — publishers are assigned to one group.
/// Default: 5 groups, configurable by admin.
model ServiceGroup {
  id          String      @id @default(uuid())
  name        String      @unique /// e.g. "Gruppe 1", "Gruppe 2"
  overseer    String?     /// Keycloak sub of group overseer
  assistant   String?     /// Keycloak sub of assistant
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  members            Publisher[]
  cleaningSchedules  CleaningSchedule[]
}

// ─── Cleaning & Garden ──────────────────────────────────────────────

enum CleaningCategory {
  grundreinigung
  sichtreinigung
  monatsreinigung
  custom
}

/// Cleaning duty types — assigned to SERVICE GROUPS on a rotating schedule.
/// Admin creates named types (e.g., "Penzberg Nord Grund").
model CleaningDuty {
  id        String           @id @default(uuid())
  name      String           /// Free-text name (e.g. "Penzberg Nord Grund")
  category  CleaningCategory @default(custom)
  isDefault Boolean          @default(false) /// True for auto-created defaults
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  schedules CleaningSchedule[]
}

/// Cleaning schedule — maps a duty to a service group on a specific date.
model CleaningSchedule {
  id             String         @id @default(uuid())
  duty           CleaningDuty   @relation(fields: [dutyId], references: [id], onDelete: Cascade)
  dutyId         String
  serviceGroup   ServiceGroup   @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade)
  serviceGroupId String
  date           DateTime       /// Scheduled date
  status         ScheduleStatus @default(scheduled)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([date])
  @@index([dutyId, date])
}

enum ScheduleStatus {
  scheduled
  completed
  skipped
}

enum GardenDutyType {
  rasen
  winterdienst
  custom
}

/// Garden duties — assigned to INDIVIDUAL PUBLISHERS (not service groups).
model GardenDuty {
  id        String         @id @default(uuid())
  name      String         /// e.g. "Rasen mähen", "Winterdienst"
  type      GardenDutyType @default(custom)
  isDefault Boolean        @default(false)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  members GardenDutyMember[]
}

/// Publisher assignment to a garden duty.
model GardenDutyMember {
  id          String    @id @default(uuid())
  duty        GardenDuty @relation(fields: [dutyId], references: [id], onDelete: Cascade)
  dutyId      String
  publisher   Publisher  @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  publisherId String
  createdAt   DateTime  @default(now())

  @@unique([dutyId, publisherId])
  @@index([publisherId])
}

// ─── Chat ────────────────────────────────────────────────────────────

model ChatSettings {
  id           String   @id @default(uuid())
  dmsEnabled   Boolean  @default(true)
  callsEnabled Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

enum CampaignTemplate {
  gedaechtnismahl
  kongress
  predigtdienstaktion
  custom
}

enum CampaignInviteStatus {
  pending
  accepted
  unavailable
}

model Campaign {
  id           String             @id @default(uuid())
  title        String
  template     CampaignTemplate
  startDate    DateTime
  endDate      DateTime
  matrixRoomId String?
  createdBy    String             /// keycloakSub of creator
  invitations  CampaignInvite[]
  createdAt    DateTime           @default(now())
  deletedAt    DateTime?          /// auto-delete 7 days after endDate
}

model CampaignInvite {
  id          String               @id @default(uuid())
  campaign    Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId  String
  publisher   Publisher            @relation(fields: [publisherId], references: [id])
  publisherId String
  status      CampaignInviteStatus @default(pending)
  respondedAt DateTime?

  @@unique([campaignId, publisherId])
  @@index([publisherId])
}
